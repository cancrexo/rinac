{
    "name": "rinac/rinac",
    "description": "RINAC - Rinac Is Not Another Calendar (WooCommerce bookings plugin)",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "autoload": {
        "psr-4": {
            "Rinac\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
